# ── Plaid ──────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here
PLAID_ENV=sandbox                          # sandbox | development | production

# Public URL where Plaid can send webhooks.
# For local dev: install ngrok (https://ngrok.com) and run:
#   ngrok http 3000
# Then set this to your ngrok URL + /plaid/webhook
WEBHOOK_URL=https://your-ngrok-url.ngrok.io/plaid/webhook

# ── APNs (Apple Push Notifications) ───────────────────────────────────────────
# Required for silent push (automatic transaction import).
# To set up:
#   1. Go to developer.apple.com > Certificates, IDs & Profiles > Keys
#   2. Create a new key with "Apple Push Notifications service (APNs)" enabled
#   3. Download the .p8 file and place it in this backend/ directory
APNS_KEY_PATH=./apns_key.p8
APNS_KEY_ID=your_key_id                    # 10-character string from Apple
APNS_TEAM_ID=your_team_id                  # Your Apple Developer Team ID
APNS_BUNDLE_ID=com.yourname.VacationCostTracker
APNS_PRODUCTION=false                      # false for dev/TestFlight, true for App Store

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
